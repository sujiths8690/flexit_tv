<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="320dp"
                android:height="180dp" />
            <gradient
                android:angle="135"
                android:endColor="#111827"
                android:startColor="#0A0A0F" />
        </shape>
    </item>
    <item
        android:bottom="40dp"
        android:left="40dp"
        android:right="40dp"
        android:top="40dp">
        <bitmap
            android:gravity="center"
            android:src="@mipmap/flexit_launcher" />
    </item>
</layer-list>
